{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tailwind CSS Forge Desktop",
  "version": "0.1.0",
  "identifier": "com.tailwindcssforge.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "security": {
      "capabilities": ["remote-localhost"]
    },
    "windows": [
      {
        "label": "main",
        "title": "Tailwind CSS Forge",
        "width": 1480,
        "height": 960,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all",
    "windows": {
      "digestAlgorithm": "sha256"
    }
  }
}
